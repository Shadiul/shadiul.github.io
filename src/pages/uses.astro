---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Item {
  name: string;
  note: string;
  href?: string;
}
interface Section {
  label: string;
  items: Item[];
}

// Real setup only — expand as the owner supplies specifics (editor theme,
// hardware details, fonts, terminal, etc.).
const sections: Section[] = [
  {
    label: 'workstations',
    items: [
      { name: 'MacBook Pro', note: 'work machine — where the scheduled vault agents live' },
      { name: 'Windows desktop', note: 'personal rig at home' },
      { name: 'Phone', note: 'mobile capture into the second brain via a Telegram bot' },
    ],
  },
  {
    label: 'frontend',
    items: [
      { name: 'React 19 + TypeScript', note: 'the day-job stack' },
      { name: 'Tailwind CSS v4', note: 'styling everywhere — work and personal' },
      { name: 'Astro', note: 'this site — static, zero JS by default' },
      { name: 'shadcn/ui', note: 'component registry, themed to my own tokens' },
      { name: 'MDX', note: 'blog posts — markdown with components when needed' },
    ],
  },
  {
    label: 'knowledge',
    items: [
      { name: 'Obsidian', note: 'the vault — plain markdown, git-synced', href: 'https://obsidian.md' },
      { name: 'Claude Code', note: 'operates the vault, builds with me daily', href: 'https://claude.com/claude-code' },
      { name: 'MCP', note: 'how other AI clients reach the vault' },
      { name: 'launchd agents', note: 'four scheduled jobs that maintain the vault on a cadence' },
      { name: 'Python', note: 'vault tooling — health checks, retrieval evals' },
    ],
  },
];
---

<Base
  title="/uses — Shadiul Huda"
  description="Tools and setup Shadiul uses daily — frontend stack, knowledge tooling, and the machines it all runs on."
  ogImage="/og/uses.png"
>
  <Header />

  <main class="mx-auto max-w-[720px] px-6 pb-16">
    <header class="pb-8 pt-[60px]">
      <p class="font-mono text-xs uppercase tracking-[0.12em] text-primary">// setup</p>
      <h1 class="mb-3.5 mt-4 text-[clamp(34px,5vw,56px)] font-semibold leading-[1.03] tracking-[-0.03em]">Uses</h1>
      <p class="max-w-[52ch] text-lg text-muted-foreground">
        The tools that survive daily use. A living list — updated as the setup evolves.
      </p>
    </header>

    <div class="flex flex-col gap-10">
      {sections.map((section) => (
        <section>
          <h2 class="mb-4 font-mono text-[15px] font-medium uppercase tracking-[0.04em] text-muted-foreground">{section.label}</h2>
          <ul class="flex flex-col">
            {section.items.map((item) => (
              <li class="grid gap-1 border-t border-border px-1 py-3.5 sm:grid-cols-[220px_1fr] sm:gap-5">
                {item.href ? (
                  <a href={item.href} class="font-medium text-primary hover:underline">{item.name}</a>
                ) : (
                  <span class="font-medium">{item.name}</span>
                )}
                <span class="text-[15px] text-muted-foreground">{item.note}</span>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </main>

  <Footer />
</Base>
