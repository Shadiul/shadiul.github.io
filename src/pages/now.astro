---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Motif from '../components/Motif.astro';

// Update the date whenever this page's content changes.
const updated = 'July 2026';

// Inline stroke icons (lucide-style, MIT). Zero JS — static SVG.
const ICONS: Record<string, string> = {
  briefcase:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>',
  moon:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>',
  book:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2Z"/></svg>',
  check:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M20 6 9 17l-5-5"/></svg>',
  hammer:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="m15 12-8.4 8.4a2.1 2.1 0 0 1-3-3L12 9"/><path d="M17.6 6.4 22 2M18 10l4-4M9.6 8.4 12 6l6 6-2.4 2.4Z"/></svg>',
  brain:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="M12 5a3 3 0 1 0-5.997.142 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.142 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/></svg>',
  globe:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><circle cx="12" cy="12" r="10"/><path d="M12 2a15 15 0 0 1 0 20 15 15 0 0 1 0-20M2 12h20"/></svg>',
};

// Focus pills — the three threads running right now (all named on the site already).
const focus = [
  { icon: 'hammer', label: 'AX Platform frontend' },
  { icon: 'brain', label: 'the second brain' },
  { icon: 'globe', label: 'this site' },
];

// Shipped recently — public, verifiable facts only.
const shipped = [
  'Rebuilt this site on Astro + Tailwind — live at shadiul.github.io',
  'Lighthouse 100 / 100 / 100 / 100 across every page',
  'Build-time OG images, mobile nav, RSS, dark + light themes',
  'First blog post drafted — a build-log of the second brain',
  'A retrieval-eval harness that scores how well the vault answers',
];
---

<Base
  title="/now — Shadiul Huda"
  description="What Shadiul is focused on right now — AX Platform frontend, this site, and a second brain that runs itself."
  ogImage="/og/now.png"
>
  <Header />

  <main class="mx-auto max-w-[720px] px-6 pb-16">
    <header class="relative overflow-hidden pb-6 pt-[60px]">
      <div class="relative z-10">
        <p class="font-mono text-xs uppercase tracking-[0.12em] text-primary">// currently</p>
        <h1 class="mb-3.5 mt-4 text-[clamp(34px,5vw,56px)] font-semibold leading-[1.03] tracking-[-0.03em]">Now</h1>
        <p class="font-mono text-[12.5px] text-faint">last updated &middot; {updated} &middot; this is a <a href="https://nownownow.com/about" class="text-muted-foreground underline underline-offset-4 hover:text-primary">/now page</a></p>
      </div>
      <Motif class="pointer-events-none absolute -right-4 top-8 hidden h-[140px] w-[240px] opacity-70 sm:block" />
    </header>

    <!-- Focus strip — the three threads running right now. -->
    <div class="mb-11 flex flex-wrap gap-2">
      {focus.map((f) => (
        <span class="inline-flex items-center gap-2 rounded-full border border-border bg-accent/40 px-3.5 py-1.5 font-mono text-[12.5px] text-foreground">
          <span class="text-primary" set:html={ICONS[f.icon]} />
          {f.label}
        </span>
      ))}
    </div>

    <div class="flex flex-col gap-10">
      <section>
        <div class="mb-3.5 flex items-center gap-3">
          <span class="grid size-9 place-items-center rounded-lg border border-border bg-accent/40 text-primary" set:html={ICONS.briefcase} />
          <h2 class="font-mono text-[15px] font-medium uppercase tracking-[0.04em] text-muted-foreground">At work</h2>
        </div>
        <p class="text-pretty text-[17px] leading-[1.7]">
          Deep in wiring the <a href="https://mevrik.tech" class="text-primary hover:underline">Mevrik</a> AX Platform
          frontend to its live backend — the console, the embeddable chat
          widget, and the shared UI kit. The platform runs customer experience
          with AI agents while humans supervise; my job is making that fast and
          honest in the browser: real data over mock, verified in the page, never
          faked green.
        </p>
      </section>

      <section>
        <div class="mb-3.5 flex items-center gap-3">
          <span class="grid size-9 place-items-center rounded-lg border border-border bg-accent/40 text-primary" set:html={ICONS.moon} />
          <h2 class="font-mono text-[15px] font-medium uppercase tracking-[0.04em] text-muted-foreground">At night</h2>
        </div>
        <p class="text-pretty text-[17px] leading-[1.7]">
          Two systems, feeding each other. The
          <a href="/projects" class="text-primary hover:underline">second brain</a> keeps
          getting smarter — scheduled agents maintain it on a cadence, contradictions
          get reconciled instead of piling up, and I measure its recall with a small
          eval harness so search quality is a number, not a vibe. And this site:
          freshly rebuilt on Astro, with a <a href="/blog" class="text-primary hover:underline">build-log post</a> drafting.
        </p>
      </section>

      <section>
        <div class="mb-3.5 flex items-center gap-3">
          <span class="grid size-9 place-items-center rounded-lg border border-border bg-accent/40 text-primary" set:html={ICONS.book} />
          <h2 class="font-mono text-[15px] font-medium uppercase tracking-[0.04em] text-muted-foreground">Learning</h2>
        </div>
        <p class="text-pretty text-[17px] leading-[1.7]">
          Mostly by building: agentic workflows — what it takes to let an AI
          operate a real system (my vault) safely, with audit trails and
          honest failure modes. The interesting problems are the boring ones:
          reconciliation, provenance, and knowing when the model is wrong.
          Reading more, too — the research on verifying and trusting software,
          and on making it work across languages.
        </p>
      </section>

      <section>
        <div class="mb-4 flex items-center gap-3">
          <span class="grid size-9 place-items-center rounded-lg border border-border bg-accent/40 text-primary" set:html={ICONS.check} />
          <h2 class="font-mono text-[15px] font-medium uppercase tracking-[0.04em] text-muted-foreground">Shipped recently</h2>
        </div>
        <ul class="flex flex-col gap-2.5">
          {shipped.map((line) => (
            <li class="flex items-start gap-3 text-[15.5px] leading-[1.6] text-muted-foreground">
              <span class="mt-0.5 shrink-0 text-primary" set:html={ICONS.check} />
              <span>{line}</span>
            </li>
          ))}
        </ul>
      </section>
    </div>
  </main>

  <Footer />
</Base>
