---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Motif from '../components/Motif.astro';
import { getPosts, formatMonth } from '@/lib/blog';

const posts = await getPosts();
---

<Base
  title="Blog — Shadiul Huda"
  description="Technical writing by Shadiul Huda — systems, frontend, and building a second brain that rewrites itself."
  ogImage="/og/blog.png"
>
  <Header />

  <header class="px-7 pb-[30px] pt-[60px]">
    <div class="relative mx-auto max-w-[1080px] overflow-hidden">
      <p class="font-mono text-xs uppercase tracking-[0.12em] text-primary">// writing</p>
      <h1 class="mb-3.5 mt-4 text-[clamp(34px,5vw,56px)] font-semibold leading-[1.03] tracking-[-0.03em]">Blog</h1>
      <p class="max-w-[52ch] text-pretty text-lg text-muted-foreground">
        Notes from building — systems that remember, interfaces that stay fast.
      </p>
      <Motif class="pointer-events-none absolute -right-2 top-1 hidden h-[130px] w-[220px] opacity-70 md:block" />
    </div>
  </header>

  <main class="mx-auto min-h-[40dvh] max-w-[1080px] px-7 pb-16">
    {posts.length === 0 ? (
      <p class="border-t border-border px-1 py-[18px] font-mono text-[13px] text-faint">
        // first posts land soon — a build-log of the second brain is drafting
      </p>
    ) : (
      <div class="flex flex-col">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}/`}
            class="group grid items-baseline gap-1.5 border-t border-border px-1 py-[18px] transition-all duration-150 hover:bg-gradient-to-r hover:from-accent hover:to-60% hover:pl-3 sm:grid-cols-[110px_1fr_auto] sm:gap-5"
          >
            <span class="font-mono text-[12.5px] tabular-nums text-faint">{formatMonth(post.data.date)}</span>
            <span class="text-lg font-medium tracking-[-0.01em] transition-colors group-hover:text-primary">
              {post.data.title}{post.data.draft && <span class="ml-2 font-mono text-[11px] uppercase text-faint">draft</span>}
            </span>
            <span class="hidden rounded-full border border-border px-2.5 py-[3px] font-mono text-[11.5px] text-muted-foreground sm:inline">{post.data.tag}</span>
          </a>
        ))}
      </div>
    )}
  </main>

  <Footer />
</Base>
