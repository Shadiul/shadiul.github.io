---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import KnowledgeGraph from '../components/KnowledgeGraph.astro';
import GitHubCard from '../components/GitHubCard.astro';
import WhatIBuild from '../components/WhatIBuild.astro';
import StackGrid from '../components/StackGrid.astro';
import { getPosts, formatMonth } from '@/lib/blog';
import { getGitHubProfile } from '@/lib/github';

const recent = (await getPosts()).slice(0, 4);
const profile = await getGitHubProfile('Shadiul');

// Social links. LinkedIn is hidden until a real URL is set (no guessed URLs).
const github = 'https://github.com/Shadiul';
const linkedin = 'https://www.linkedin.com/in/shadiul/';
const email = 'shadiul@mevrik.tech';

// Inline stroke icons (lucide-style, MIT). Zero JS.
const ICONS: Record<string, string> = {
  monitor:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>',
  brain:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M12 5a3 3 0 1 0-5.997.142 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.142 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/></svg>',
  book:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2Z"/></svg>',
};

const doing = [
  {
    icon: 'monitor',
    title: 'Frontend engineering',
    body: "I lead the frontend for Mevrik's AI-agent platform — inbox, an AI voice call center, video calling, CRM, chat widget, workflow canvas, agent studio and dashboards — and own how it ships. React, Next.js, TanStack, Cloudflare.",
    href: '#build',
  },
  {
    icon: 'book',
    title: 'Research & writing',
    body: 'Published on HCI and developer experience, and increasingly drawn to what makes AI-era software verifiable and trustworthy. I write about what I build.',
    href: '/blog',
  },
  {
    icon: 'brain',
    title: 'Systems that remember',
    body: 'By night I build a self-rewriting second brain — sources rewrite old notes, contradictions reconcile themselves, and scheduled agents keep it current while I sleep.',
    href: '/projects',
  },
];

const proof = ['frontend lead · 2+ yrs', 'voice + video AI', 'ships to edge · CI/CD', 'real-time · WebSockets', 'design systems'];

const stats = [
  { value: '5+', label: 'years of experience' },
  { value: '2+', label: 'yrs leading frontend' },
  { value: '9+', label: 'product surfaces' },
  { value: '3', label: 'publications' },
];

---

<Base title="Shadiul Huda — Senior Software Engineer" description="Mohammad Shadiul Huda — Senior Software Engineer and frontend lead of the Mevrik AX Platform, in Dhaka. I build interfaces and systems that remember.">
  <Header />

  <main>
  <!-- hero -->
  <header class="relative overflow-hidden border-b border-border px-7 pb-16 pt-[74px]">
    <div class="mx-auto grid max-w-[1080px] items-center gap-10 md:grid-cols-[1.05fr_.95fr]">
      <div>
        <div class="mb-8 flex items-center gap-4">
          {profile.avatarDataUri ? (
            <img
              src={profile.avatarDataUri}
              alt="Mohammad Shadiul Huda"
              width="54" height="54"
              class="size-[54px] flex-none rounded-full border-[1.5px] border-primary object-cover shadow-[0_0_18px_-4px_var(--primary)]"
            />
          ) : (
            <span
              class="flex size-[54px] flex-none items-center justify-center rounded-full border-[1.5px] border-primary bg-secondary font-mono text-[22px] font-medium text-primary shadow-[0_0_18px_-4px_var(--primary)]"
              aria-hidden="true">S</span>
          )}
          <div class="flex flex-col gap-1.5">
            <span class="font-mono text-[13px] uppercase tracking-[0.1em] text-primary">Mohammad Shadiul Huda</span>
            <span class="text-[13px] text-muted-foreground">Frontend lead &middot; Mevrik AX Platform &middot; Dhaka, BD</span>
          </div>
        </div>
        <h1 class="mb-5 text-[clamp(38px,6vw,68px)] font-semibold leading-[1.02] tracking-[-0.03em] text-balance">
          I build interfaces<br />and <span class="text-muted-foreground">systems that<br />remember.</span>
        </h1>
        <p class="mb-8 max-w-[46ch] text-pretty text-[19px] text-muted-foreground">
          I lead the frontend for an AI-agent CX platform by day, and build
          tools that think for themselves by night. I care about fast
          interfaces, honest systems, and notes that write themselves. Deep
          in React, Next.js and the TanStack — shipping to the edge on
          Cloudflare Workers, and increasingly drawn to what makes software
          trustworthy.
        </p>
        <div class="flex flex-wrap items-center gap-3">
          <a href="/projects" class="btn btn-primary"><span class="caret" aria-hidden="true">&rsaquo;</span> view projects</a>
          <a href="/blog" class="btn btn-ghost">read the blog</a>
        </div>
        <!-- social links -->
        <div class="mt-6 flex flex-wrap items-center gap-5 font-mono text-[13px] text-muted-foreground">
          <a href={github} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 transition-colors hover:text-primary" aria-label="GitHub">
            <svg viewBox="0 0 24 24" fill="currentColor" width="15" height="15" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.5 11.5 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" /></svg>
            github
          </a>
          {linkedin && (
            <a href={linkedin} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 transition-colors hover:text-primary" aria-label="LinkedIn">
              <svg viewBox="0 0 24 24" fill="currentColor" width="15" height="15" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z" /></svg>
              linkedin
            </a>
          )}
          <a href={`mailto:${email}`} class="inline-flex items-center gap-1.5 transition-colors hover:text-primary" aria-label="Email">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="15" height="15" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" /></svg>
            email
          </a>
        </div>
      </div>
      <div class="relative order-first overflow-hidden rounded-2xl border border-border bg-gradient-to-b from-card to-background md:order-none">
        <GitHubCard profile={profile} />
      </div>
    </div>
  </header>

  <!-- by the numbers -->
  <section class="border-b border-border px-7 py-[60px]">
    <div class="mx-auto max-w-[1080px]">
      <div class="mb-[26px] flex items-baseline justify-between gap-4">
        <h2 class="font-mono text-[15px] font-medium uppercase tracking-[0.04em] text-muted-foreground">By the numbers</h2>
      </div>
      <div class="grid grid-cols-2 gap-[18px] md:grid-cols-4" data-reveal-group>
        {stats.map((s) => (
          <div class="reveal rounded-[14px] border border-border bg-card p-5">
            <div class="text-[28px] font-semibold tracking-[-0.02em]">{s.value}</div>
            <div class="mt-1 font-mono text-[12.5px] text-muted-foreground">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- what I do -->
  <section class="border-b border-border px-7 py-[60px]">
    <div class="mx-auto max-w-[1080px]">
      <div class="mb-[26px] flex items-baseline justify-between gap-4">
        <h2 class="font-mono text-[15px] font-medium uppercase tracking-[0.04em] text-muted-foreground">What I do</h2>
        <a href="/about" class="font-mono text-[13px] text-primary hover:underline">more about me &rarr;</a>
      </div>
      <div class="grid gap-[18px] md:grid-cols-3" data-reveal-group>
        {doing.map((d) => (
          <a href={d.href} data-spotlight class="reveal spotlight group flex flex-col rounded-[14px] border border-border bg-card p-6 transition-colors hover:border-primary/60">
            <span class="mb-4 grid size-11 place-items-center rounded-[11px] border border-border bg-accent/40 text-primary" set:html={ICONS[d.icon]} />
            <h3 class="mb-2 text-[18px] font-semibold tracking-[-0.01em] transition-colors group-hover:text-primary">{d.title}</h3>
            <p class="text-pretty text-[14.5px] leading-relaxed text-muted-foreground">{d.body}</p>
          </a>
        ))}
      </div>
      <div class="mt-[22px] flex flex-wrap gap-2">
        {proof.map((p) => (
          <span class="rounded-full border border-border bg-accent/40 px-3 py-[5px] font-mono text-[12px] text-muted-foreground">{p}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- what I build -->
  <section id="build" class="border-b border-border px-7 py-[60px]">
    <div class="mx-auto max-w-[1080px]">
      <div class="mb-[26px] flex items-baseline justify-between gap-4">
        <h2 class="font-mono text-[15px] font-medium uppercase tracking-[0.04em] text-muted-foreground">What I build</h2>
      </div>
      <WhatIBuild />
    </div>
  </section>

  <!-- stack & tools -->
  <section class="border-b border-border px-7 py-[60px]">
    <div class="mx-auto max-w-[1080px]">
      <div class="mb-[26px] flex items-baseline justify-between gap-4">
        <h2 class="font-mono text-[15px] font-medium uppercase tracking-[0.04em] text-muted-foreground">Stack &amp; tools</h2>
      </div>
      <StackGrid />
    </div>
  </section>

  <!-- featured project -->
  <section class="border-b border-border px-7 py-[60px]">
    <div class="mx-auto max-w-[1080px]">
      <div class="mb-[26px] flex items-baseline justify-between gap-4">
        <h2 class="font-mono text-[15px] font-medium uppercase tracking-[0.04em] text-muted-foreground">Featured project</h2>
        <a href="/projects" class="font-mono text-[13px] text-primary hover:underline">all projects &rarr;</a>
      </div>
      <div class="reveal spotlight grid overflow-hidden rounded-2xl border border-border bg-card md:grid-cols-2" data-spotlight>
        <div class="p-8">
          <span class="mb-3.5 inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.1em] text-primary">
            <span aria-hidden="true">&#9670;</span> Flagship
          </span>
          <h3 class="mb-3 text-[27px] font-semibold tracking-[-0.02em]">The Second Brain</h3>
          <p class="mb-[18px] text-[15.5px] text-muted-foreground">
            A self-rewriting knowledge base that Claude operates as a living
            second brain — sources rewrite existing pages, contradictions
            reconcile automatically, and scheduled agents maintain the vault
            while I sleep.
          </p>
          <div class="flex flex-wrap gap-2">
            {['Obsidian', 'Claude', 'MCP', 'AI-first notes', 'cron agents'].map((chip) => (
              <span class="rounded-full border border-border px-[11px] py-[5px] font-mono text-[11.5px] text-muted-foreground">{chip}</span>
            ))}
          </div>
        </div>
        <div class="relative min-h-[180px] border-t border-border bg-gradient-to-br from-accent to-secondary md:min-h-[260px] md:border-l md:border-t-0">
          <div class="absolute inset-0">
            <KnowledgeGraph nodes={20} speed={0.16} density={0.09} reach={120} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- recent writing -->
  <section class="border-b border-border px-7 py-[60px]">
    <div class="mx-auto max-w-[1080px]">
      <div class="mb-[26px] flex items-baseline justify-between gap-4">
        <h2 class="font-mono text-[15px] font-medium uppercase tracking-[0.04em] text-muted-foreground">Recent writing</h2>
        <a href="/blog" class="font-mono text-[13px] text-primary hover:underline">all posts &rarr;</a>
      </div>
      {recent.length === 0 ? (
        <p class="border-t border-border px-1 py-[18px] font-mono text-[13px] text-faint">
          // first posts land soon — a build-log of the second brain is drafting
        </p>
      ) : (
        <div class="flex flex-col" data-reveal-group>
          {recent.map((post) => (
            <a
              href={`/blog/${post.id}/`}
              class="reveal group grid items-baseline gap-1.5 border-t border-border px-1 py-[18px] transition-all duration-150 hover:bg-gradient-to-r hover:from-accent hover:to-60% hover:pl-3 sm:grid-cols-[110px_1fr_auto] sm:gap-5"
            >
              <span class="font-mono text-[12.5px] tabular-nums text-faint">{formatMonth(post.data.date)}</span>
              <span class="text-lg font-medium tracking-[-0.01em] transition-colors group-hover:text-primary">
                {post.data.title}{post.data.draft && <span class="ml-2 font-mono text-[11px] uppercase text-faint">draft</span>}
              </span>
              <span class="hidden rounded-full border border-border px-2.5 py-[3px] font-mono text-[11.5px] text-muted-foreground sm:inline">{post.data.tag}</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
  </main>

  <Footer />
  <script src="../scripts/spotlight.ts"></script>
</Base>
