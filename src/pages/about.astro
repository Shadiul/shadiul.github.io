---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Motif from '../components/Motif.astro';
import Eyebrow from '../components/Eyebrow.astro';
import StackGrid from '../components/StackGrid.astro';
import { getGitHubProfile } from '@/lib/github';

const profile = await getGitHubProfile('Shadiul');

// Publications — verified real (jisem confirmed first-author; the two cloud/ML
// papers are on Shadiul's résumé and matched to their published records).
const publications = [
  {
    title: 'Designing Developer-Facing Interfaces: An HCI Approach to Improving DX in Frontend Tooling',
    venue: 'Journal of Information Systems Engineering & Management · Vol 9 (4s), 2024 · pp 2098–2114',
    note: 'Applied HCI methods to frontend tooling — measured a 22.5% drop in cognitive load and 32% fewer errors in developer tasks.',
    authors: 'with Shuvojit Devnath, Tanbir Hasan Taz',
    href: 'https://www.jisem-journal.com/index.php/journal/article/view/12488',
  },
  {
    title: 'GPT-Powered Virtual Assistants for Intelligent Cloud Service Management',
    venue: 'IEEE · 2025',
    note: 'NLP-driven assistants that manage cloud services through conversational interfaces.',
    authors: '',
    href: 'https://ieeexplore.ieee.org/document/11198967/',
  },
  {
    title: 'Serverless AI: Revolutionizing Cloud-Based Machine Learning Workflows',
    venue: '2024',
    note: 'Serverless ML workflows — 42.6% faster execution and 38.4% lower cost vs. container-based baselines.',
    authors: '',
    href: 'https://www.researchgate.net/publication/399873553',
  },
];

// Research interests (SOUL + research-statement facts; no grad-school specifics).
const research = [
  'software verification',
  'formal methods',
  'metamorphic testing',
  'HCI',
  'accessibility',
  'multilingual NLP',
];

// Recognition — senior signals: award, leadership, mentorship, engineering impact.
const honors = [
  '"React Ninja" — internal recognition at Mevrik',
  'Frontend lead — 2+ years owning the AX Platform frontend',
  'Mentor engineers through code review since 2023',
  'Drove the design-system migration to Base UI — a 66-component kit',
];

// Inline stroke icons (lucide-style, MIT). Zero JS.
const ICONS: Record<string, string> = {
  gauge:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="17" height="17"><path d="m12 14 4-4M3.34 19a10 10 0 1 1 17.32 0"/></svg>',
  shield:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="17" height="17"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1Z"/></svg>',
  ask:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="17" height="17"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/><path d="M9.5 9a2.5 2.5 0 1 1 3 2.45c-.6.14-1 .66-1 1.3v.25"/><path d="M12 17h.01"/></svg>',
  refresh:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="17" height="17"><path d="M3 12a9 9 0 0 1 15-6.7L21 8M21 3v5h-5M21 12a9 9 0 0 1-15 6.7L3 16M3 21v-5h5"/></svg>',
};

// Public-friendly versions of stated working principles (SOUL, 2026-07-11).
const principles = [
  {
    icon: 'gauge',
    title: 'Verify live, not just green',
    body: 'Passing typecheck and CI is not "done". Done is clicking through the real thing against real APIs.',
  },
  {
    icon: 'shield',
    title: "Don't fake it, don't delete it",
    body: 'If a feature is not ready, disable it honestly. Never ship a UI that pretends, and never rip out work that still has a job to do.',
  },
  {
    icon: 'ask',
    title: 'Ask before deciding',
    body: 'Ambiguous product calls get surfaced before the change lands — nobody should discover a decision after the fact.',
  },
  {
    icon: 'refresh',
    title: 'Notes that write themselves',
    body: 'If knowledge only lives in my head, it is a liability. Everything worth keeping goes into a system that keeps it current.',
  },
];
---

<Base
  title="About — Shadiul Huda"
  description="Shadiul Huda — Utso — Senior Software Engineer & frontend lead at Mevrik in Dhaka. Interfaces by day, self-maintaining systems by night."
  ogImage="/og/about.png"
>
  <Header />

  <main class="mx-auto max-w-[720px] px-6 pb-16">
    <header class="relative pb-8 pt-[60px]">
      <!-- Motif clipped to header bounds by its own wrapper, so the avatar's
           glow (below) isn't clipped by an overflow-hidden on the header. -->
      <div class="pointer-events-none absolute inset-0 overflow-hidden">
        <Motif class="absolute -right-4 top-4 hidden h-[140px] w-[240px] opacity-60 md:block" />
      </div>
      <div class="relative z-10">
        <Eyebrow>about</Eyebrow>
        <div class="mt-7 flex items-center gap-5">
          {profile.avatarDataUri ? (
            <img
              src={profile.avatarDataUri}
              alt="Mohammad Shadiul Huda"
              width="66" height="66"
              class="size-[66px] flex-none rounded-full border-[1.5px] border-primary object-cover shadow-[0_0_18px_-4px_var(--primary)]"
            />
          ) : (
            <span
              class="flex size-[66px] flex-none items-center justify-center rounded-full border-[1.5px] border-primary bg-secondary font-mono text-[26px] font-medium text-primary shadow-[0_0_18px_-4px_var(--primary)]"
              aria-hidden="true">S</span>
          )}
          <div>
            <h1 class="text-[clamp(30px,4.5vw,44px)] font-semibold leading-[1.08] tracking-[-0.03em] text-balance">
              I'm Shadiul Huda — <span class="text-muted-foreground">Utso to most people.</span>
            </h1>
          </div>
        </div>
      </div>
    </header>

    <div class="flex flex-col gap-[22px] text-pretty text-[17.5px] leading-[1.7] text-foreground">
      <p>
        I'm a Senior Software Engineer and the frontend lead at <a href="https://mevrik.tech" target="_blank" rel="noopener" class="text-primary hover:underline">Mevrik</a>,
        working from Dhaka, Bangladesh. We build AI agents that run customer
        experience while humans supervise what matters — I own the frontend
        and the range of surfaces it takes: the operator console and its
        omni-channel inbox, a CRM and segment builder, an embeddable chat
        widget with a one-line install script, an n8n-style workflow canvas,
        an AI agent studio, and the analytics dashboards — all on the shared
        UI kit they're built from. I've led the frontend for 2+ years and
        mentor the team through code review.
      </p>
      <p>
        It goes past the UI. I own how the frontend ships — Cloudflare, CI/CD
        and Docker, handed clean to devops — and I build the platform's voice
        and video AI: an AI-driven call center on Voximplant (voicebots,
        campaigns, transcription, call summaries) and in-app video with screen
        share and device control. Plus the internal devtools the team runs on.
      </p>
      <p>
        Nights are for systems. The one I keep coming back to is my
        <a href="/projects" class="text-primary hover:underline">second brain</a> —
        a knowledge base Claude operates for me, where new information rewrites
        old pages and scheduled agents reconcile the vault while I sleep. This
        site is another one of those builds: it doubles as the
        <a href="/blog" class="text-primary hover:underline">build log</a>.
      </p>
      <p>
        I work across models and providers — Claude, GPT, Gemini, DeepSeek, and
        local Llama or Gemma on Ollama — and the craft I care about most is
        context engineering: the right information in front of a model at the
        right moment, with MCP, agent skills and workflows doing the wiring.
      </p>
      <p>
        I care about interfaces that stay fast, systems that stay honest, and
        notes that stay current without me babysitting them.
      </p>
    </div>

    <!-- path here -->
    <section class="mt-12">
      <h2 class="mb-5 font-mono text-[15px] font-medium uppercase tracking-[0.04em] text-muted-foreground">Path here</h2>
      <ol class="flex flex-col gap-3.5 border-l border-border pl-5 tabular-nums">
        <li class="relative text-[14.5px] leading-relaxed text-muted-foreground before:absolute before:-left-[24px] before:top-[8px] before:size-[7px] before:rounded-full before:bg-primary">
          <span class="font-mono text-xs text-faint">2022 — present</span><br />
          <span class="text-foreground">Senior Software Engineer &amp; frontend lead, Mevrik</span> — Dhaka
        </li>
        <li class="relative text-[14.5px] leading-relaxed text-muted-foreground before:absolute before:-left-[24px] before:top-[8px] before:size-[7px] before:rounded-full before:bg-border">
          <span class="font-mono text-xs text-faint">2021 — 2022</span><br />
          <span class="text-foreground">Software Engineer, NexusLab</span> — fintech — real-time trading dashboards, web + mobile
        </li>
        <li class="relative text-[14.5px] leading-relaxed text-muted-foreground before:absolute before:-left-[24px] before:top-[8px] before:size-[7px] before:rounded-full before:bg-border">
          <span class="font-mono text-xs text-faint">2020 — 2021</span><br />
          <span class="text-foreground">Mobile App Developer, Antooba Corp</span>
        </li>
        <li class="relative text-[14.5px] leading-relaxed text-muted-foreground before:absolute before:-left-[24px] before:top-[8px] before:size-[7px] before:rounded-full before:bg-border">
          <span class="font-mono text-xs text-faint">2018 — 2019</span><br />
          <span class="text-foreground">Unity / AR-VR Developer, GrapView</span>
        </li>
        <li class="relative text-[14.5px] leading-relaxed text-muted-foreground before:absolute before:-left-[24px] before:top-[8px] before:size-[7px] before:rounded-full before:bg-border">
          <span class="font-mono text-xs text-faint">2017 — 2021</span><br />
          <span class="text-foreground">B.Sc. Computer Science &amp; Engineering</span> — Daffodil International University
        </li>
      </ol>
    </section>

    <!-- where I'm headed -->
    <section class="mt-12">
      <h2 class="mb-5 font-mono text-[15px] font-medium uppercase tracking-[0.04em] text-muted-foreground">Where I'm headed</h2>
      <div class="flex flex-col gap-[18px] text-pretty text-[16.5px] leading-[1.7] text-foreground">
        <p>
          Lately I'm pulled less toward shipping features and more toward the
          engineering principles that make software <span class="text-primary">trustworthy</span> —
          software verification, formal methods, and metamorphic testing for the
          AI/ML parts that are hardest to pin down.
        </p>
        <p>
          My angle on it is human. Navigating an English-first industry as a
          native Bengali speaker taught me how much interface and language decide
          who technology actually works for — so I care about this most for
          multilingual and accessibility-critical systems. Long term, I want to
          build HCI and NLP tools tailored to needs like that, back home.
        </p>
      </div>
      <div class="mt-5 flex flex-wrap gap-2">
        {research.map((chip) => (
          <span class="rounded-full border border-border px-[11px] py-[5px] font-mono text-[11.5px] text-muted-foreground">{chip}</span>
        ))}
      </div>
    </section>

    <!-- publications -->
    <section class="mt-12">
      <div class="mb-5 flex items-baseline justify-between gap-4">
        <h2 class="font-mono text-[15px] font-medium uppercase tracking-[0.04em] text-muted-foreground">Publications</h2>
        <span class="font-mono text-[12px] tabular-nums text-faint">{publications.length} papers</span>
      </div>
      <div class="flex flex-col gap-3.5">
        {publications.map((p) => (
          <a href={p.href} target="_blank" rel="noopener" class="group block rounded-[14px] border border-border bg-card p-5 transition-colors hover:border-primary/60">
            <h3 class="text-[16px] font-semibold leading-snug tracking-[-0.01em] transition-colors group-hover:text-primary">
              {p.title} <span class="font-mono text-[12px] text-faint transition-colors group-hover:text-primary">&#8599;</span>
            </h3>
            <p class="mt-2 font-mono text-[12px] tabular-nums text-faint">{p.venue}</p>
            <p class="mt-3 text-pretty text-[14.5px] leading-relaxed text-muted-foreground">{p.note}</p>
            {p.authors && <p class="mt-2 font-mono text-[12px] text-faint">{p.authors}</p>}
          </a>
        ))}
      </div>
    </section>

    <!-- stack (shared component, also on the home page) -->
    <section class="mt-12">
      <h2 class="mb-5 font-mono text-[15px] font-medium uppercase tracking-[0.04em] text-muted-foreground">What I work with</h2>
      <StackGrid />
    </section>

    <!-- principles -->
    <section class="mt-12">
      <h2 class="mb-5 font-mono text-[15px] font-medium uppercase tracking-[0.04em] text-muted-foreground">How I work</h2>
      <div class="grid gap-[14px] sm:grid-cols-2">
        {principles.map((p) => (
          <div class="rounded-[14px] border border-border bg-card p-5">
            <div class="mb-2 flex items-center gap-2.5">
              <span class="grid size-8 flex-none place-items-center rounded-lg border border-border bg-accent/40 text-primary" set:html={ICONS[p.icon]} />
              <h3 class="text-[15.5px] font-semibold tracking-[-0.01em]">{p.title}</h3>
            </div>
            <p class="text-pretty text-[14px] leading-relaxed text-muted-foreground">{p.body}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- recognition -->
    <section class="mt-12">
      <h2 class="mb-5 font-mono text-[15px] font-medium uppercase tracking-[0.04em] text-muted-foreground">Recognition</h2>
      <ul class="grid gap-3 sm:grid-cols-2">
        {honors.map((item) => (
          <li class="relative pl-5 text-[14.5px] leading-relaxed text-muted-foreground before:absolute before:left-0 before:top-[8px] before:size-[6px] before:rounded-full before:bg-primary">
            {item}
          </li>
        ))}
      </ul>
    </section>

    <!-- reach -->
    <section class="mt-12">
      <h2 class="mb-5 font-mono text-[15px] font-medium uppercase tracking-[0.04em] text-muted-foreground">Say hello</h2>
      <div class="flex flex-wrap gap-3">
        <a href="https://github.com/Shadiul" target="_blank" rel="noopener" class="btn btn-primary">github</a>
        <a href="mailto:shadiul@mevrik.tech" class="btn btn-ghost">email me</a>
        <a href="/now" class="btn btn-ghost">what I'm doing now <span class="caret" aria-hidden="true">&rarr;</span></a>
      </div>
    </section>
  </main>

  <Footer />
</Base>
