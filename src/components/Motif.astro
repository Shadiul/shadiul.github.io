---
/**
 * Static knowledge-graph motif — a still echo of the site's identity element
 * (the live KnowledgeGraph canvas). Zero JS. Decorative only (aria-hidden).
 * Pass positioning/sizing via `class`; the viewBox coordinates are fixed.
 */
interface Props {
  class?: string;
}
const { class: cls } = Astro.props;
---

<svg class={cls} viewBox="0 0 240 140" fill="none" aria-hidden="true">
  <g stroke="var(--primary)" stroke-opacity="0.28" stroke-width="1">
    <line x1="36" y1="28" x2="110" y2="56" />
    <line x1="110" y1="56" x2="196" y2="30" />
    <line x1="110" y1="56" x2="84" y2="112" />
    <line x1="110" y1="56" x2="186" y2="100" />
    <line x1="196" y1="30" x2="186" y2="100" />
  </g>
  <g fill="var(--primary)">
    <circle cx="110" cy="56" r="4.5" />
    <circle cx="36" cy="28" r="3" fill-opacity="0.75" />
    <circle cx="196" cy="30" r="3.5" fill-opacity="0.85" />
    <circle cx="84" cy="112" r="2.5" fill-opacity="0.6" />
    <circle cx="186" cy="100" r="3" fill-opacity="0.7" />
  </g>
</svg>
