---

<div class="flex flex-col gap-3" data-reveal-group>
  {/* legend */}
  <div class="mb-1 flex items-center gap-2 font-mono text-[10.5px] text-faint">
    <span class="flex items-center gap-[3px]" aria-hidden="true">
      <span class="size-[6px] rounded-full bg-primary"></span>
      <span class="size-[6px] rounded-full bg-primary"></span>
      <span class="size-[6px] rounded-full bg-primary"></span>
      <span class="size-[6px] rounded-full bg-border"></span>
      <span class="size-[6px] rounded-full bg-border"></span>
    </span>
    <span>depth of use — core to occasional</span>
  </div>

  {categories.map((cat) => (
    <div class="reveal grid grid-cols-[1fr] items-center gap-x-5 gap-y-2 border-t border-border/60 pt-3 sm:grid-cols-[128px_84px_1fr]">
      {/* layer label */}
      <div class="flex items-baseline gap-2">
        <span class="font-mono text-[11px] uppercase tracking-[0.1em] text-muted-foreground">{cat.name}</span>
        <span class="font-mono text-[9.5px] text-faint sm:hidden">{cat.note}</span>
      </div>
      {/* proficiency meter — 5-dot matrix */}
      <span class="flex items-center gap-[4px]" title={`depth of use: ${cat.level}/5`} aria-label={`depth of use ${cat.level} of 5`}>
        {Array.from({ length: 5 }).map((_, i) => (
          <span class:list={["size-[6px] rounded-full transition-colors", i < cat.level ? "bg-primary" : "bg-border"]} />
        ))}
      </span>
      {/* tech chips */}
      <div class="flex flex-wrap gap-1.5">
        {cat.items.map((it) => (
          <span class="group inline-flex items-center gap-1.5 rounded-full border border-border bg-card px-2.5 py-[5px] font-mono text-[11.5px] text-muted-foreground transition-colors hover:border-primary/60 hover:text-primary">
            <span
              class="inline-flex text-muted-foreground transition-colors group-hover:text-primary [&_svg]:size-[13px]"
              set:html={ICONS[it.icon]}
            />
            {it.label}
          </span>
        ))}
      </div>
    </div>
  ))}
</div>
