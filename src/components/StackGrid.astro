interface CatItem {
  label: string;
  icon: string;
}
interface Category {
  name: string;
  /** Depth of use, 1–5. Reflects a frontend-deep profile (backend is consumed, not owned). */
  level: number;
  note: string;
  items: CatItem[];
}

